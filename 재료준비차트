                                                        min="0"
                                                        value={item.unit || ''}
                                                        onChange={(e) => updateVegItem(idx, 'unit', e.target.value)}
                                                    />
                                                </td>
                                                <td>
                                                    <input 
                                                        type="number" 
                                                        min="0"
                                                        value={item.backFridge || ''}
                                                        onChange={(e) => updateVegItem(idx, 'backFridge', e.target.value)}
                                                    />
                                                </td>
                                                <td>
                                                    <input 
                                                        type="number" 
                                                        min="0"
                                                        value={item.mainFridge || ''}
                                                        onChange={(e) => updateVegItem(idx, 'mainFridge', e.target.value)}
                                                    />
                                                </td>
                                                <td className="result-cell">{total}</td>
                                                <td className="prepare-cell">{prepare}</td>
                                                <td className="note-cell">{item.stockNote}</td>
                                                <td className="no-print">
                                                    <button 
                                                        className="btn btn-primary" 
                                                        style={{fontSize: '11px', padding: '4px 8px'}}
                                                        onClick={() => openSettings(item, 'veg', idx)}
                                                    >
                                                        ⚙️
                                                    </button>
                                                    <br/>
                                                    <button 
                                                        className="delete-row-btn"
                                                        style={{marginTop: '4px'}}
                                                        onClick={() => deleteItem('veg', idx)}
                                                    >
                                                        삭제
                                                    </button>
                                                </td>
                                            </tr>
                                        );
                                    })}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    
                    {showSettings && editingItem && (
                        <SettingsModal 
                            item={editingItem.item}
                            onClose={() => {
                                setShowSettings(false);
                                setEditingItem(null);
                            }}
                            onSave={saveSettings}
                        />
                    )}
                </div>
            );
        }
        
        function SettingsModal({ item, onClose, onSave }) {
            const [settings, setSettings] = useState(item.settings || {});
            const [name, setName] = useState(item.name || '');
            const [waterTray, setWaterTray] = useState(item.waterTray || 'O');
            const [shelfLife, setShelfLife] = useState(item.shelfLife || '');
            const [note, setNote] = useState(item.note || '');
            const [stockNote, setStockNote] = useState(item.stockNote || '');
            
            const updateSetting = (day, value) => {
                setSettings({
                    ...settings,
                    [day]: value === '' ? 0 : Number(value)
                });
            };
            
            const handleSave = () => {
                const updatedItem = { 
                    ...item, 
                    settings, 
                    name, 
                    waterTray, 
                    shelfLife,
                    note
                };
                if (item.stockNote !== undefined) {
                    updatedItem.stockNote = stockNote;
                }
                onSave(updatedItem);
            };
            
            return (
                <div className="modal" onClick={onClose}>
                    <div className="modal-content" onClick={(e) => e.stopPropagation()}>
                        <div className="modal-header">
                            <h2>⚙️ {item.name} 설정</h2>
                            <button className="close-btn" onClick={onClose}>×</button>
                        </div>
                        
                        <div className="modal-body">
                            <div className="setting-item">
                                <h3>📝 품목 정보</h3>
                                <div style={{
                                    background: '#f8f9fa',
                                    padding: '10px',
                                    borderRadius: '6px',
                                    marginBottom: '15px',
                                    fontSize: '12px',
                                    color: '#666'
                                }}>
                                    <strong>메모</strong>: 재료의 특성 설명 (예: 1팩=2캠, 2팩기준 등)<br/>
                                    <strong>참고</strong>: 냉장 재료 위치는 테이블 아래 통합 참고란에 작성
                                </div>
                                <div className="setting-grid">
                                    <div className="setting-field">
                                        <label>품목명</label>
                                        <input 
                                            type="text"
                                            value={name}
                                            onChange={(e) => setName(e.target.value)}
                                            placeholder="품목명"
                                        />
                                    </div>
                                    <div className="setting-field">
                                        <label>메모</label>
                                        <input 
                                            type="text"
                                            value={note}
                                            onChange={(e) => setNote(e.target.value)}
                                            placeholder="예: 1팩=2캠"
                                        />
                                    </div>
                                    <div className="setting-field">
                                        <label>물받침</label>
                                        <select 
                                            value={waterTray}
                                            onChange={(e) => setWaterTray(e.target.value)}
                                            style={{
                                                width: '100%',
                                                padding: '6px',
                                                border: '1px solid #ddd',
                                                borderRadius: '4px',
                                                fontSize: '13px'
                                            }}
                                        >
                                            <option value="O">O (필요)</option>
                                            <option value="X">X (불필요)</option>
                                        </select>
                                    </div>
                                    <div className="setting-field">
                                        <label>유통기한</label>
                                        <input 
                                            type="text"
                                            value={shelfLife}
                                            onChange={(e) => setShelfLife(e.target.value)}
                                            placeholder="예: 소분2"
                                        />
                                    </div>
                                    {item.stockNote !== undefined && (
                                        <div className="setting-field">
                                            <label>재고기준</label>
                                            <input 
                                                type="text"
                                                value={stockNote}
                                                onChange={(e) => setStockNote(e.target.value)}
                                                placeholder="예: 비닐기준"
                                            />
                                        </div>
                                    )}
                                </div>
                            </div>
                            
                            <div className="highlight-box">
                                <h3>🎯 공휴일 설정</h3>
                                <div className="setting-grid">
                                    <div className="setting-field">
                                        <label>오늘이 공휴일인 경우</label>
                                        <input 
                                            type="number" 
                                            min="0"
                                            value={settings.today_holiday || ''}
                                            onChange={(e) => updateSetting('today_holiday', e.target.value)}
                                            placeholder="추가 수량"
                                        />
                                    </div>
                                    <div className="setting-field">
                                        <label>내일이 공휴일인 경우</label>
                                        <input 
                                            type="number" 
                                            min="0"
                                            value={settings.holiday || ''}
                                            onChange={(e) => updateSetting('holiday', e.target.value)}
                                            placeholder="추가 수량"
                                        />
                                    </div>
                                </div>
                            </div>
                            
                            <div className="setting-item">
                                <h3>📅 요일별 추가 수량 (내일 기준)</h3>
                                <div style={{
                                    background: '#e3f2fd',
                                    padding: '10px',
                                    borderRadius: '6px',
                                    marginBottom: '15px',
                                    fontSize: '12px',
                                    color: '#1565c0',
                                    border: '1px solid #2196f3'
                                }}>
                                    ⚠️ <strong>중요:</strong> 요일별 추가는 <strong>"내일"</strong> 기준입니다.<br/>
                                    예: 월요일 +1 → 오늘이 일요일일 때 자동 적용됨
                                </div>
                                <div className="setting-grid">
                                    <div className="setting-field">
                                        <label>월요일</label>
                                        <input 
                                            type="number" 
                                            min="0"
                                            value={settings.monday || ''}
                                            onChange={(e) => updateSetting('monday', e.target.value)}
                                        />
                                    </div>
                                    <div className="setting-field">
                                        <label>화요일</label>
                                        <input 
                                            type="number" 
                                            min="0"
                                            value={settings.tuesday || ''}
                                            onChange={(e) => updateSetting('tuesday', e.target.value)}
                                        />
                                    </div>
                                    <div className="setting-field">
                                        <label>수요일</label>
                                        <input 
                                            type="number" 
                                            min="0"
                                            value={settings.wednesday || ''}
                                            onChange={(e) => updateSetting('wednesday', e.target.value)}
                                        />
                                    </div>
                                    <div className="setting-field">
                                        <label>목요일</label>
                                        <input 
                                            type="number" 
                                            min="0"
                                            value={settings.thursday || ''}
                                            onChange={(e) => updateSetting('thursday', e.target.value)}
                                        />
                                    </div>
                                    <div className="setting-field">
                                        <label>금요일</label>
                                        <input 
                                            type="number" 
                                            min="0"
                                            value={settings.friday || ''}
                                            onChange={(e) => updateSetting('friday', e.target.value)}
                                        />
                                    </div>
                                    <div className="setting-field">
                                        <label>토요일</label>
                                        <input 
                                            type="number" 
                                            min="0"
                                            value={settings.saturday || ''}
                                            onChange={(e) => updateSetting('saturday', e.target.value)}
                                        />
                                    </div>
                                    <div className="setting-field">
                                        <label>일요일</label>
                                        <input 
                                            type="number" 
                                            min="0"
                                            value={settings.sunday || ''}
                                            onChange={(e) => updateSetting('sunday', e.target.value)}
                                        />
                                    </div>
                                </div>
                            </div>
                            
                            <div style={{marginTop: '20px', textAlign: 'right'}}>
                                <button className="btn btn-secondary" onClick={onClose} style={{marginRight: '10px'}}>
                                    취소
                                </button>
                                <button className="btn btn-primary" onClick={handleSave}>
                                    저장
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            );
        }
        
        ReactDOM.render(<MaterialChart />, document.getElementById('root'));
    </script>
</body>
</html>
