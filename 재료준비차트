        function MaterialChart() {
            const [currentDate, setCurrentDate] = useState(new Date());
            const [isHolidayTomorrow, setIsHolidayTomorrow] = useState(false);
            const [isHolidayToday, setIsHolidayToday] = useState(false);
            const [showSettings, setShowSettings] = useState(false);
            const [editingItem, setEditingItem] = useState(null);
            const [calculationMode, setCalculationMode] = useState(() => {
                return localStorage.getItem('calculationMode') || 'all';
            });
            const [isLocked, setIsLocked] = useState(() => {
                return localStorage.getItem('isLocked') === 'true';
            });
            const [meatMemoNote, setMeatMemoNote] = useState(() => {
                return localStorage.getItem('meatMemoNote') || '';
            });
            const [authorName, setAuthorName] = useState(() => {
                return localStorage.getItem('authorName') || '';
            });
            
            const [meatData, setMeatData] = useState(() => {
                const saved = localStorage.getItem('meatData');
                if (saved) {
                    return JSON.parse(saved);
                }
                return DEFAULT_MEAT_ITEMS.map(item => ({
                    ...item,
                    unit: 0,
                    backFridge: 0,
                    mainFridge: 0
                }));
            });
            
            const [vegData, setVegData] = useState(() => {
                const saved = localStorage.getItem('vegData');
                if (saved) {
                    return JSON.parse(saved);
                }
                return DEFAULT_VEG_ITEMS.map(item => ({
                    ...item,
                    unit: 0,
                    backFridge: 0,
                    mainFridge: 0
                }));
            });
            
            useEffect(() => {
                localStorage.setItem('meatData', JSON.stringify(meatData));
            }, [meatData]);
            
            useEffect(() => {
                localStorage.setItem('vegData', JSON.stringify(vegData));
            }, [vegData]);
            
            useEffect(() => {
                localStorage.setItem('authorName', authorName);
            }, [authorName]);
            
            useEffect(() => {
                localStorage.setItem('calculationMode', calculationMode);
            }, [calculationMode]);
            
            useEffect(() => {
                localStorage.setItem('isLocked', isLocked);
            }, [isLocked]);
            
            useEffect(() => {
                localStorage.setItem('meatMemoNote', meatMemoNote);
            }, [meatMemoNote]);
            
            const getDayOfWeek = () => {
                const days = ['일', '월', '화', '수', '목', '금', '토'];
                return days[currentDate.getDay()];
            };
            
            const getFormattedDate = () => {
                const year = currentDate.getFullYear();
                const month = currentDate.getMonth() + 1;
                const date = currentDate.getDate();
                return `${year}년 ${month}월 ${date}일 (${getDayOfWeek()})`;
            };
            
            const getTomorrowDay = () => {
                const tomorrow = new Date(currentDate);
                tomorrow.setDate(tomorrow.getDate() + 1);
                const days = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
                return days[tomorrow.getDay()];
            };
            
            const getTomorrowDayKorean = () => {
                const tomorrow = new Date(currentDate);
                tomorrow.setDate(tomorrow.getDate() + 1);
                const days = ['일', '월', '화', '수', '목', '금', '토'];
                return days[tomorrow.getDay()];
            };
            
            const isTomorrowWeekend = () => {
                const tomorrowDay = getTomorrowDay();
                return tomorrowDay === 'saturday' || tomorrowDay === 'sunday';
            };
            
            const getTodayDay = () => {
                const days = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
                return days[currentDate.getDay()];
            };
            
            const updateMeatItem = (index, field, value) => {
                const newData = [...meatData];
                if (field === 'name' || field === 'note') {
                    newData[index][field] = value;
                } else {
                    newData[index][field] = value === '' ? 0 : Number(value);
                }
                setMeatData(newData);
            };
            
            const updateVegItem = (index, field, value) => {
                const newData = [...vegData];
                if (field === 'name' || field === 'note') {
                    newData[index][field] = value;
                } else {
                    newData[index][field] = value === '' ? 0 : Number(value);
                }
                setVegData(newData);
            };
            
            const calculateTotal = (item) => {
                return item.unit + item.backFridge + item.mainFridge;
            };
            
            const getAdjustedAmount = (item, type) => {
                const tomorrowDay = getTomorrowDay();
                let baseAmount = item[type] || 0;
                let adjustment = 0;
                
                // 내일 기준 설정 적용 (예: 내일이 월요일이면 monday 설정 적용)
                if (item.settings && item.settings[tomorrowDay]) {
                    adjustment += item.settings[tomorrowDay];
                }
                
                // 오늘이 공휴일이면 today_holiday 설정 적용
                if (isHolidayToday && item.settings && item.settings.today_holiday) {
                    adjustment += item.settings.today_holiday;
                }
                
                // 내일이 공휴일이면 holiday 설정 적용
                if (isHolidayTomorrow && item.settings && item.settings.holiday) {
                    adjustment += item.settings.holiday;
                }
                
                return baseAmount + adjustment;
            };
            
            const calculatePrepare = (item) => {
                const adjustedMiddle = getAdjustedAmount(item, 'middle');
                const adjustedClosing = getAdjustedAmount(item, 'closing');
                const total = calculateTotal(item);
                
                let need = 0;
                if (calculationMode === 'middle') {
                    need = adjustedMiddle;
                } else if (calculationMode === 'closing') {
                    need = adjustedClosing;
                } else {
                    need = adjustedMiddle + adjustedClosing;
                }
                
                // 토마토는 특별 계산식: ((필요량) - 합계) / 2 올림
                if (item.name === '토마토') {
                    const result = (need - total) / 2;
                    return result > 0 ? Math.ceil(result) : 0;
                }
                
                const result = need - total;
                return result > 0 ? result : 0;
            };
            
