            border: 1px solid #4caf50;
            border-radius: 6px;
            padding: 12px;
            margin-bottom: 20px;
            font-size: 12px;
            color: #2e7d32;
        }
        
        @media print {
            body * {
                visibility: hidden;
            }
            
            #printArea, #printArea * {
                visibility: visible;
            }
            
            #printArea {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
            }
            
            .no-print {
                display: none !important;
            }
        }
        
        .print-content {
            font-family: "Courier New", monospace;
            font-size: 14px;
            line-height: 1.6;
            padding: 20px;
        }
        
        .print-header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px dashed #333;
            padding-bottom: 10px;
        }
        
        .print-item {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            border-bottom: 1px dotted #ccc;
        }
        
        .print-footer {
            margin-top: 20px;
            text-align: center;
            border-top: 2px dashed #333;
            padding-top: 10px;
        }
        
        @media (max-width: 768px) {
            body {
                padding: 5px;
            }
            
            .header h1 {
                font-size: 20px;
            }
            
            .section {
                padding: 15px 10px;
            }
            
            input[type="number"] {
                width: 50px;
                padding: 4px;
                font-size: 12px;
            }
            
            th, td {
                padding: 6px 4px;
                font-size: 11px;
            }
            
            .header-controls {
                width: 100%;
            }
            
            .btn {
                font-size: 12px;
                padding: 6px 12px;
            }
            
            .calc-mode-selector {
                width: 100%;
            }
            
            .calc-mode-btn {
                flex: 1;
                font-size: 11px;
                padding: 6px 8px;
            }
        }
    </style>
</head>
